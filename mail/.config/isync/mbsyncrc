IMAPAccount gmail
# Address to connect to
Host imap.gmail.com
User nicolas.morazotti@gmail.com
# To store the password in an encrypted file use PassCmd instead of Pass
PassCmd "gpg2 -q --for-your-eyes-only --no-tty -d ~/.mailpass.gpg" 
# Use SSL
TLSType IMAPS
# The following line should work. If get certificate errors, uncomment the two following lines and read the "Troubleshooting" section.
CertificateFile /etc/ssl/certs/ca-certificates.crt

IMAPStore gmail-remote
Account gmail

MaildirStore gmail-local
Subfolders Verbatim
# The trailing "/" is important
Path /home/nicolas/.local/share/mail/
Inbox /home/nicolas/.local/share/mail/inbox

Channel gmail
Master :gmail-remote:
Slave :gmail-local:
# Exclude everything under the internal [Gmail] folder, except the interesting folders
Patterns * ![Gmail]* "[Gmail]/Sent Mail" "[Gmail]/Starred" "[Gmail]/All Mail"
# Or include everything
# Patterns *
# Automatically create missing mailboxes, both locally and on the server
Create Both
# Save the synchronization state files in the relevant directory
SyncState *

IMAPAccount ufscar
Host imap.ufscar.br
User nicolas.morazotti@ufscar.br
PassCmd "gpg2 -q --for-your-eyes-only --no-tty -d ~/.ufscar-mailpass.gpg"
TLSType IMAPS
CertificateFile /etc/ssl/certs/ca-certificates.crt

IMAPStore ufscar-remote
Account ufscar

MaildirStore ufscar-local
Subfolders Verbatim
Path /home/nicolas/.local/share/ufscar-mail/
Inbox /home/nicolas/.local/share/ufscar-mail/inbox

Channel ufscar
Master :ufscar-remote:
Slave :ufscar-local:
Patterns *
Create Both
SyncState *

# Se o IMAP/usuário não for exatamente `imap.ufscar.br`, me diga qual é o servidor (ou mande a tela/config do webmail) que eu ajusto. Para sincronizar: `mbsync -a` ou `mbsync ufscar`.