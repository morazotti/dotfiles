#!/bin/bash

papesdir="$HOME/Pictures/Wallpapers/"

papes=`find "$HOME/Pictures/Wallpapers/" -maxdepth 1 -type f | sed "s|/home.*Wallpapers/||g" | rofi -dmenu -sort -i -p "Which wallpaper do you want to use? "`
#[ "$papes" != "" ] && ln -sf "/$HOME/Pictures/Wallpapers/$papes" "/$HOME/.temp/wallpaper" && feh --bg-fill "/home/nicolas/.temp/wallpaper"
[[ -z "$papes" ]] && exit || ln -sf "$papesdir/$papes" "$HOME/.cache/wallpaper" && wal -i "$papesdir/$papes" 
