#!/bin/bash

free_hd(){
    used="$(df -hH | grep -i '/dev/sda3' | awk '{print $3}')"
    total="$(df -hH | grep -i '/dev/sda3' | awk '{print $2}')"
    echo ’éĀ $used / $total 
}

free_ram(){
    used="$(free -h --si | grep -i 'mem' | awk '{print $3}')"
    total="$(free -h --si | grep -i 'mem' | awk '{print $2}')"
    echo ’ł│ $used / $total | tr -d i 
}

# has_drive(){
#     is_drive_active="$(ps aux | grep odrive | grep -v grep )"
#     if [ "$is_drive_active" != "" ]; then
