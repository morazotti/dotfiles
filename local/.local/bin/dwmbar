#     if [ "$is_skype_active" != "" ]; then
# 	echo "’ģŠ |"
#     fi
# }


has_onedrive(){
    is_onedrive_active="$(ps aux | grep onedrive | grep -v grep )"
    if [ "$is_onedrive_active" != "" ]; then
    	echo "’āé |"
    fi
    
}

has_dropbox(){
    is_dropbox_active="$(ps aux | grep dropbox | grep -v grep )"
    if [ "$is_dropbox_active" != "" ]; then
	echo "’ģ½ |"
    fi
}

email(){
    echo " ’āĀ $(notmuch count tag:unread)" #" unread mails"
}

song(){
    song=`mpc -h 127.0.0.1 -p 6601 | sed 1q`
    is_playing=`mpc -h 127.0.0.1 -p 6601 | grep paused`
    if [ "$is_playing" = "" ]; then
	echo "$song ’ģä"
    fi
    if [ "$is_playing" != "" ]; then
	echo "$song ’Ŗŗ"
    fi
}

battery(){
    bat=`acpi | tr , " " | awk '{print $3" "$4}'`
    status=`echo $bat | awk '{print $1}'`
    percent=`echo $bat | awk '{print $2}'| tr -d %`
    if [ "$status" = "Full" ]; then
	echo "’ā¦ Full"
    fi
    if [ "$status" = "Charging" ]; then
	echo "’ć” $percent%"
    fi
    if [ "$status" = "Discharging" ]; then
	case $percent in
	    [0-1]*)
		echo "’ēä $percent%"
		;;
	    [2-4]*)
		echo "’ēā $percent%"
		;;
	    [5-6]*)
		echo "’ēé $percent%"
		;;
	    [7-8]*)
		echo "’ēü $percent%"
		;;
	    *) 
		echo "’ēĆ $percent%"
		;;
	esac
    fi
}

clock(){
    text=`date +"%F %R" `
    echo "’ü│ $text"
}

internet(){
    wifi=`nmcli device | grep wifi | awk '{$1=$2=$3=""; print $0}' | sed "s/^ *//g;1q"`
    eth=`nmcli device | grep ethernet | awk '{$1=$2=$3=""; print $0}' | sed "s/^ *//g"`
    [ "$eth" != "--" ] && echo "’ā© $eth |"
    [ "$wifi" != "--" ] && echo "’ć½ $wifi |"
}

volume(){
    vol=`amixer | grep "Front Left: Playback" | awk '{print $(NF-1)}' | tr -d '[]%'`
    is_mute="$(amixer | grep "Front Left: Playback" | awk '{print $NF}')"
    if [ "$is_mute" = "[off]" ] ; then
	echo "’łä ’Ć”   $vol%"
    else
	echo "’łģ ’Ć© $vol%"
    fi
}

updates(){
    upd=`pacman -Qu | wc -l`
    echo "’ĆÖ $upd"
}

echo " | $(song) | $(has_dropbox) $(has_onedrive)$(free_hd) | $(free_ram) | $(updates) | $(email) | $(volume) | $(internet) $(clock) | $(battery) "
