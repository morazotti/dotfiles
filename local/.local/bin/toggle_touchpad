# toggle state of touchpad

#tpid=`xinput list | grep 'Elan Touchpad' | sed 's/.*id\=\([0-9]\+\).*/\1/g'`
tpid=9

#declare -i status
status=`xinput list-props ${tpid} | grep Device\ Enabled | awk '{print $NF}'`

if [ 0 -eq ${status} ] ; then
    xinput enable ${tpid}
else
    xinput disable ${tpid}
fi
