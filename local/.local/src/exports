#!/bin/sh

export XDG_CONFIG_HOME=$HOME/.config
export XDG_DATA_HOME=$HOME/.local/share
export TERMINFO=/usr/share/terminfo
export ZSH=$HOME/.oh-my-zsh
export STARSHIP_CONFIG="$XDG_CONFIG_HOME"/starship/starship.toml
export MPD_HOST=127.0.0.1
export MPD_PORT=6600
export CARGO_HOME="$XDG_DATA_HOME"/cargo
export CURL_CA_BUNDLE=/etc/ssl/certs/ca-certificates.crt
export GTK2_RC_FILES="$XDG_CONFIG_HOME"/gtk-2.0/gtkrc
export DOCKER_CONFIG="$XDG_CONFIG_HOME"/docker
export DVDCSS_CACHE="$XDG_DATA_HOME"/dvdcss
export JULIA_DEPOT_PATH="$XDG_DATA_HOME/julia:$JULIA_DEPOT_PATH"
export JULIAUP_DEPOT_PATH="$XDG_DATA_HOME/julia"
export KDEHOME="$XDG_CONFIG_HOME"/kde
export MACHINE_STORAGE_PATH="$XDG_DATA_HOME"/docker-machine
export MATHEMATICA_USERBASE="$XDG_CONFIG_HOME"/mathematica
export OPENAI_API_KEY=$(gpg2 -q --for-your-eyes-only --no-tty -d ~/.authinfo.gpg | awk '/api.openai.com/ {print $NF}')
export NVM_DIR="$XDG_DATA_HOME"/nvm
export NMBGIT="$XDG_DATA_HOME"/notmuch/nmbug
export PASSWORD_STORE_DIR="$XDG_DATA_HOME"/pass
export PPYDEVD_DISABLE_FILE_VALIDATION=1
export PATH=$PATH:$HOME/.local/bin
export QEMO_AUDIO_DRV=alsa
export SSH_AUTH_SOCK="$XDG_RUNTIME_DIR/ssh-agent.socket"
export TMUX_TMPDIR="$XDG_RUNTIME_DIR"
export TEXMFHOME=$XDG_DATA_HOME/texmf
export TEXMFVAR=$XDG_CACHE_HOME/texlive/texmf-var
export TEXMFCONFIG=$XDG_CONFIG_HOME/texlive/texmf-config
export DATABASEDIR="$XDG_DATA_HOME"/mail
export WINEPREFIX="$XDG_DATA_HOME"/wineprefixes/default
export _Z_DATA="$XDG_DATA_HOME"/z
export _ZO_DATA_DIR="$XDG_DATA_HOME"/zoxide
